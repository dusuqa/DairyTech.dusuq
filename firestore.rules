rules_version = '2';

// ════════════════════════════════════════════════════════════════════════
// DUSUQ — Multi-Tenant Firestore Security Rules
//
// DESIGN NOTE ON request.auth.token VS get():
// Your proposed pattern used get(/databases/.../users/$(uid)).data.orgId inside
// every rule. This works, but each get() is a real document read that Firestore
// bills you for AND counts against the 10-document-access limit per rule
// evaluation. For a list query returning 50 milk records, naive rules would
// each try to call get() — bad performance, easy to silently fail.
//
// Instead: custom claims (orgId + role) are minted server-side by a Cloud
// Function (syncUserClaims, see functions/index.js) whenever a user doc is
// created or its role/orgId changes. Claims live on the auth token itself —
// reading them in a rule is FREE (no Firestore read at all). The user doc in
// Firestore remains the source of truth for the app's UI (Flutter reads it
// directly via StreamBuilder), while claims are the FAST, CHEAP source of
// truth for security rules. The two are kept in sync by the Cloud Function;
// they're never reconciled inside a rule.
//
// Token shape after the Cloud Function runs:
//   { orgId: "org_abc123", role: "OrgAdmin" }
// SuperAdmin has orgId == null on their token.
// ════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──
    function isSignedIn() {
      return request.auth != null;
    }

    function role() {
      return request.auth.token.role;
    }

    function orgId() {
      return request.auth.token.orgId;
    }

    function isSuperAdmin() {
      return isSignedIn() && role() == 'SuperAdmin';
    }

    function isOrgAdmin() {
      return isSignedIn() && role() == 'OrgAdmin';
    }

    function isFarmer() {
      return isSignedIn() && role() == 'Farmer';
    }

    // True if the resource being read/written belongs to the caller's org.
    // SuperAdmin bypasses this entirely (checked separately, OR'd in).
    function belongsToCallerOrg(data) {
      return isSignedIn() && data.orgId == orgId();
    }

    // Immutability guard: orgId can never change after a document is created.
    function orgIdUnchanged() {
      return request.resource.data.orgId == resource.data.orgId;
    }

    // ── users/{uid} ──
    // A user can always read their OWN profile (needed to bootstrap role/orgId
    // client-side on first load, before claims are even relevant).
    // OrgAdmin can read/write users within their own org (to manage farmers).
    // SuperAdmin can read/write any user.
    // Nobody can self-assign a role or orgId — only OrgAdmin/SuperAdmin can set
    // those fields, enforced by restricting writes to those roles entirely
    // (a Farmer can update their own displayName but never their role/orgId —
    // see field-level check below).
    match /users/{uid} {
      allow read: if isSignedIn() && (
        request.auth.uid == uid ||
        isSuperAdmin() ||
        (isOrgAdmin() && resource.data.orgId == orgId())
      );

      // Creation only via Cloud Function (Admin SDK bypasses rules) when
      // inviting a farmer, OR self-creation restricted to safe fields only
      // (first-time OrgAdmin signup flow creates their own org + user doc
      // together — see signUpOrgAdmin Cloud Function).
      allow create: if false; // all user creation goes through Cloud Functions

      allow update: if isSignedIn() && (
        isSuperAdmin() ||
        (isOrgAdmin() && resource.data.orgId == orgId()
          && request.resource.data.orgId == resource.data.orgId) ||
        (request.auth.uid == uid
          // Self-update: can only touch displayName/phone, never role/orgId/status
          && request.resource.data.role == resource.data.role
          && request.resource.data.orgId == resource.data.orgId
          && request.resource.data.status == resource.data.status)
      );

      allow delete: if isSuperAdmin() ||
        (isOrgAdmin() && resource.data.orgId == orgId());
    }

    // ── organizations/{orgId} ──
    match /organizations/{orgDocId} {
      allow read: if isSignedIn() && (isSuperAdmin() || orgId() == orgDocId);
      allow create: if false; // provisioned via Cloud Function on signup
      allow update: if isSuperAdmin() ||
        (isOrgAdmin() && orgId() == orgDocId
          // OrgAdmin can edit settings/name but not planTier or status
          && request.resource.data.planTier == resource.data.planTier
          && request.resource.data.status == resource.data.status);
      allow delete: if isSuperAdmin();
    }

    // ── Shared rule block for all 6 operational collections ──
    // animals, milk_records, feed_expenses, breeding_records,
    // medical_records, finance_records all follow the identical pattern:
    //   - SuperAdmin: full read/write across every org (global aggregate view)
    //   - OrgAdmin / Farmer: read/write ONLY within their own org
    //   - orgId is immutable once set
    //   - orgId must match the writer's own org at creation time (can't write
    //     into someone else's tenant even if you guessed a valid orgId)
    //
    // NOTE: Firestore's rules language does not support calling a shared
    // function body across separate `match` blocks as a substitute for the
    // allow rules themselves — functions can return booleans used INSIDE a
    // rule (like belongsToCallerOrg above), but the rule definitions per
    // collection must be written out explicitly. The repetition below is
    // intentional, not an oversight.

    match /animals/{docId} {
      allow read: if isSuperAdmin() || belongsToCallerOrg(resource.data);
      allow create: if isSignedIn() && !isSuperAdmin()
        && request.resource.data.orgId == orgId();
      allow update: if (isSuperAdmin() || belongsToCallerOrg(resource.data))
        && orgIdUnchanged();
      allow delete: if isSuperAdmin() ||
        (isOrgAdmin() && belongsToCallerOrg(resource.data));
      // Farmers can create/update but NOT delete animal records — only
      // OrgAdmin/SuperAdmin can remove an animal from the herd.
    }

    match /milk_records/{docId} {
      allow read: if isSuperAdmin() || belongsToCallerOrg(resource.data);
      allow create: if isSignedIn() && !isSuperAdmin()
        && request.resource.data.orgId == orgId();
      allow update: if (isSuperAdmin() || belongsToCallerOrg(resource.data))
        && orgIdUnchanged();
      allow delete: if isSuperAdmin() ||
        (isOrgAdmin() && belongsToCallerOrg(resource.data));
    }

    match /feed_expenses/{docId} {
      allow read: if isSuperAdmin() || belongsToCallerOrg(resource.data);
      allow create: if isSignedIn() && !isSuperAdmin()
        && request.resource.data.orgId == orgId();
      allow update: if (isSuperAdmin() || belongsToCallerOrg(resource.data))
        && orgIdUnchanged();
      allow delete: if isSuperAdmin() ||
        (isOrgAdmin() && belongsToCallerOrg(resource.data));
    }

    match /breeding_records/{docId} {
      allow read: if isSuperAdmin() || belongsToCallerOrg(resource.data);
      allow create: if isSignedIn() && !isSuperAdmin()
        && request.resource.data.orgId == orgId();
      allow update: if (isSuperAdmin() || belongsToCallerOrg(resource.data))
        && orgIdUnchanged();
      allow delete: if isSuperAdmin() ||
        (isOrgAdmin() && belongsToCallerOrg(resource.data));
    }

    match /medical_records/{docId} {
      allow read: if isSuperAdmin() || belongsToCallerOrg(resource.data);
      allow create: if isSignedIn() && !isSuperAdmin()
        && request.resource.data.orgId == orgId();
      allow update: if (isSuperAdmin() || belongsToCallerOrg(resource.data))
        && orgIdUnchanged();
      allow delete: if isSuperAdmin() ||
        (isOrgAdmin() && belongsToCallerOrg(resource.data));
    }

    match /finance_records/{docId} {
      // Financial data: Farmers can create entries (e.g. logging an expense)
      // but cannot read the org-wide financial dashboard — only their own
      // submitted entries. OrgAdmin/SuperAdmin see everything in-org.
      allow read: if isSuperAdmin() ||
        (isOrgAdmin() && belongsToCallerOrg(resource.data)) ||
        (isFarmer() && belongsToCallerOrg(resource.data)
          && resource.data.createdBy == request.auth.uid);
      allow create: if isSignedIn() && !isSuperAdmin()
        && request.resource.data.orgId == orgId()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if (isSuperAdmin() ||
        (isOrgAdmin() && belongsToCallerOrg(resource.data)))
        && orgIdUnchanged();
      allow delete: if isSuperAdmin() ||
        (isOrgAdmin() && belongsToCallerOrg(resource.data));
    }

    // Deny everything else by default (implicit in Firestore rules, stated
    // here for clarity — no catch-all match block needed).
  }
}
